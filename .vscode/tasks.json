{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "compile mac",
            "command": "clang++",
            "args": [
                "-std=c++17",
                "-g",
                "main.cpp",
                "../Headers/Player/Player.cpp",
                "../Headers/Enemy/Enemy.cpp",
                "../Headers/Village/Village.cpp",
                "../Headers/Miscellaneous/Miscellaneous.cpp",
                "../Headers/Battle/Battle.cpp",
                "-I../Headers/Player",
                "-I../Headers/Enemy",
                "-I../Headers/Village",
                "-I../Headers/Miscellaneous",
                "-I../Headers/Battle",
                "-o",
                "main_mac"
            ],
            "options": {
                "cwd": "${workspaceFolder}/RPG/Main"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "compile mac"
        },
        {
            "type": "shell",
            "label": "compile win",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "${workspaceFolder}/RPG/Main/main.cpp",
                "${workspaceFolder}/RPG/Headers/Player/Player.cpp",
                "${workspaceFolder}/RPG/Headers/Enemy/Enemy.cpp",
                "${workspaceFolder}/RPG/Headers/Village/Village.cpp",
                "${workspaceFolder}/RPG/Headers/Miscellaneous/Miscellaneous.cpp",
                "${workspaceFolder}/RPG/Headers/Battle/Battle.cpp",
                "/I${workspaceFolder}/RPG/Headers/Player",
                "/I${workspaceFolder}/RPG/Headers/Enemy",
                "/I${workspaceFolder}/RPG/Headers/Village",
                "/I${workspaceFolder}/RPG/Headers/Miscellaneous",
                "/I${workspaceFolder}/RPG/Headers/Battle",
                "/Fe:${workspaceFolder}/RPG/Main/main_win.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}/RPG/Main"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "compile win"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Task generated by Debugger."
        }
    ]
}